# Postgres connection string
DATABASE_URL="postgresql://user:password@localhost:5432/hiring"

# NextAuth
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Domain gate for sign-ins. Comma-separated list.
ALLOWED_EMAIL_DOMAINS="engram-lab.com"

# Resume storage: Google Drive via user's OAuth.
# The Google OAuth scope includes drive.file, so no extra credentials are needed.
# Resumes are uploaded to a "Engram Hiring — Resumes" folder in the uploader's Drive
# and shared as "anyone with the link" so all team members can view them.

# ---- Phase 2: Slack sync (not required for Phase 1) ----
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""
SLACK_HIRING_CHANNEL_ID=""
