// Hiring Platform — data model
// Phase 1: User/Position/Candidate/Comment/Rating/Interviewer
// Phase 2 (dormant, migrated early to avoid schema rewrite): SlackMessage/Flag

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js tables (Prisma adapter) ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(MEMBER)
  createdAt     DateTime  @default(now())

  accounts       Account[]
  sessions       Session[]
  interviewing   Interviewer[]
  authoredComments Comment[]  @relation("CommentAuthor")
  authoredRatings  Rating[]   @relation("RatingAuthor")
  createdCandidates Candidate[] @relation("CandidateCreator")
  resolvedFlags    Flag[]     @relation("FlagResolver")
}

enum UserRole {
  ADMIN
  MEMBER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Hiring domain ----------

enum Department {
  ENGINEERING
  BUSINESS_OPS
  RESEARCH
  OTHER
}

model Position {
  id          String     @id @default(cuid())
  title       String
  department  Department
  description String?    @db.Text
  status      String     @default("open") // "open" | "closed"
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  candidates Candidate[]
}

enum Stage {
  TOP_OF_FUNNEL
  REACHED_OUT
  SCREENING
  TECHNICAL
  ONSITE
  OFFER
  OFFER_ACCEPTED
  REJECTED
  FOLLOW_UP
}

model Candidate {
  id          String    @id @default(cuid())
  name        String
  positionId  String
  position    Position  @relation(fields: [positionId], references: [id])
  stage       Stage     @default(TOP_OF_FUNNEL)
  source      String?
  resumeUrl   String?
  resumeKey   String?   // storage key for deletion
  websiteUrl  String?
  githubUrl   String?
  email       String?
  notes       String?   @db.Text
  followUpAt  DateTime?
  archived    Boolean   @default(false)
  createdById String?
  createdBy   User?     @relation("CandidateCreator", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  interviewers   Interviewer[]
  comments       Comment[]
  ratings        Rating[]
  slackMessages  SlackMessage[] @relation("CandidateSlackMessages")

  @@index([stage])
  @@index([positionId])
}

model Interviewer {
  candidateId String
  userId      String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([candidateId, userId])
}

enum CommentSource {
  MANUAL
  SLACK
}

model Comment {
  id              String        @id @default(cuid())
  candidateId     String
  candidate       Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  authorId        String
  author          User          @relation("CommentAuthor", fields: [authorId], references: [id])
  body            String        @db.Text
  source          CommentSource @default(MANUAL)
  slackMessageTs  String?
  createdAt       DateTime      @default(now())

  @@index([candidateId])
}

enum Facet {
  TECHNICAL
  EXECUTIVE_PRESENCE
  SENIORITY
  PROBLEM_SOLVING
  CULTURE
}

model Rating {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation("RatingAuthor", fields: [authorId], references: [id])
  facet       Facet
  score       Int       // 1..5
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([candidateId, authorId, facet])
  @@index([candidateId])
}

// ---------- Phase 2: dormant tables (no routes wired yet) ----------

model SlackMessage {
  id                 String     @id @default(cuid())
  ts                 String     @unique
  channel            String
  userSlackId        String?
  userName           String?
  text               String     @db.Text
  permalink          String?
  fetchedAt          DateTime   @default(now())
  matchedCandidateId String?
  matchedCandidate   Candidate? @relation("CandidateSlackMessages", fields: [matchedCandidateId], references: [id])
  reconciled         Boolean    @default(false)
  urgent             Boolean    @default(false)
  urgentReason       String?

  flags Flag[]

  @@index([reconciled])
  @@index([urgent])
}

model Flag {
  id             String       @id @default(cuid())
  slackMessageId String
  slackMessage   SlackMessage @relation(fields: [slackMessageId], references: [id], onDelete: Cascade)
  reason         String
  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?        @relation("FlagResolver", fields: [resolvedById], references: [id])
  createdAt      DateTime     @default(now())
}
